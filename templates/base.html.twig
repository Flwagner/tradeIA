<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><rect width=%22128%22 height=%22128%22 rx=%2220%22 fill=%22%230f172a%22/><text x=%2222%22 y=%2278%22 font-size=%2246%22 fill=%22%23ffffff%22 font-family=%22Arial%22>tIA</text></svg>">
        {% block stylesheets %}
            <style>
                :root {
                    color-scheme: light;
                    --bg: #f7f8fa;
                    --panel: #ffffff;
                    --text: #18202f;
                    --muted: #647084;
                    --line: #d9dee8;
                    --accent: #0f766e;
                    --accent-soft: #d7f3ef;
                }

                * {
                    box-sizing: border-box;
                }

                body {
                    margin: 0;
                    min-height: 100vh;
                    background: var(--bg);
                    color: var(--text);
                    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
                }

                .app-shell {
                    width: min(960px, calc(100% - 32px));
                    margin: 0 auto;
                    padding: 72px 0;
                }

                .intro {
                    max-width: 680px;
                }

                .eyebrow {
                    margin: 0 0 12px;
                    color: var(--accent);
                    font-size: 0.78rem;
                    font-weight: 700;
                    letter-spacing: 0;
                    text-transform: uppercase;
                }

                h1 {
                    margin: 0;
                    font-size: clamp(2.5rem, 9vw, 5rem);
                    line-height: 1;
                }

                .intro p:last-child {
                    margin: 20px 0 0;
                    color: var(--muted);
                    font-size: 1.1rem;
                    line-height: 1.65;
                }

                .status-grid {
                    display: grid;
                    grid-template-columns: repeat(3, minmax(0, 1fr));
                    gap: 12px;
                    margin-top: 40px;
                }

                .status-grid article {
                    border: 1px solid var(--line);
                    border-radius: 8px;
                    background: var(--panel);
                    padding: 18px;
                }

                .status-grid strong,
                .status-grid span {
                    display: block;
                }

                .status-grid strong {
                    font-size: 0.85rem;
                }

                .status-grid span {
                    margin-top: 8px;
                    color: var(--muted);
                }

                @media (max-width: 680px) {
                    .app-shell {
                        padding: 48px 0;
                    }

                    .status-grid {
                        grid-template-columns: 1fr;
                    }
                }
            </style>
        {% endblock %}

        {% block javascripts %}
        {% endblock %}
    </head>
    <body>
        {% block body %}{% endblock %}
    </body>
</html>
