{% extends 'base.html.twig' %}

{% block title %}Backtest tactique · tradeIA{% endblock %}

{% block body %}
    {% set settings = result.settings %}
    {% set summary = result.summary %}

    <main class="app-shell">
        <header class="topbar">
            <div class="brand">
                <strong>tradeIA</strong>
                <span>Backtest tactique</span>
            </div>
            <a class="text-button" href="{{ path('app_home') }}">Retour</a>
        </header>

        <section class="detail-hero" aria-labelledby="backtest-title">
            <div>
                <p class="eyebrow">1 ETF · 1000 EUR · stop loss</p>
                <h1 id="backtest-title">Rotation tactique</h1>
                <p class="detail-name">
                    Achat du meilleur score momentum quand le portefeuille est en cash. Sortie au stop loss, puis nouvelle sélection au jour de cotation suivant.
                </p>
            </div>

            <form class="backtest-form" method="get">
                <div class="field compact-field">
                    <label for="period">Période</label>
                    <select id="period" name="period">
                        {% for key, period in settings.periods %}
                            <option value="{{ key }}" {{ settings.periodKey == key ? 'selected' : '' }}>{{ period.label }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="field compact-field">
                    <label for="stop_loss">Stop loss</label>
                    <input id="stop_loss" name="stop_loss" type="number" min="1" max="25" step="0.5" value="{{ settings.stopLossPercent }}">
                </div>

                <button type="submit">Tester</button>
            </form>
        </section>

        <section class="table-panel chart-panel" aria-labelledby="equity-title">
            <header>
                <div>
                    <h2 id="equity-title">Courbe de capital</h2>
                    <span class="muted">
                        {% if settings.startDate and settings.endDate %}
                            {{ settings.startDate|date('d/m/Y') }} - {{ settings.endDate|date('d/m/Y') }}
                        {% else %}
                            Historique indisponible
                        {% endif %}
                    </span>
                </div>
                <span class="muted">Hors frais, spread et fiscalité</span>
            </header>

            <div class="chart-summary">
                <div>
                    <span class="muted">Capital final</span>
                    <strong>{{ summary.finalValue|number_format(2, '.', ' ') }} EUR</strong>
                </div>
                <div>
                    <span class="muted">Performance</span>
                    <strong class="{{ summary.returnPercent >= 0 ? 'positive' : 'negative' }}">{{ summary.returnPercent|number_format(2, '.', ' ') }} %</strong>
                </div>
                <div>
                    <span class="muted">Max drawdown</span>
                    <strong>{{ summary.maxDrawdown is not null ? summary.maxDrawdown|number_format(2, '.', ' ') ~ ' %' : '-' }}</strong>
                </div>
                <div>
                    <span class="muted">Trades fermés</span>
                    <strong>{{ summary.tradeCount }}</strong>
                </div>
                <div>
                    <span class="muted">Taux de réussite</span>
                    <strong>{{ summary.winRate is not null ? summary.winRate|number_format(1, '.', ' ') ~ ' %' : '-' }}</strong>
                </div>
                <div>
                    <span class="muted">Gain moyen / trade</span>
                    <strong>{{ summary.averageTradeReturn is not null ? summary.averageTradeReturn|number_format(2, '.', ' ') ~ ' %' : '-' }}</strong>
                </div>
            </div>

            <div class="price-chart">
                {% if result.chart.path %}
                    <svg viewBox="{{ result.chart.viewBox }}" role="img" aria-label="Courbe de capital backtest">
                        <line class="chart-grid-line" x1="28" y1="28" x2="732" y2="28"></line>
                        <line class="chart-grid-line" x1="28" y1="140" x2="732" y2="140"></line>
                        <line class="chart-grid-line" x1="28" y1="252" x2="732" y2="252"></line>
                        <path class="chart-line" d="{{ result.chart.path }}"></path>
                        <circle class="chart-point" cx="{{ result.chart.first.x }}" cy="{{ result.chart.first.y }}" r="4"></circle>
                        <circle class="chart-point last" cx="{{ result.chart.last.x }}" cy="{{ result.chart.last.y }}" r="5"></circle>
                    </svg>
                {% else %}
                    <div class="empty-state">Pas assez de données pour tracer la courbe.</div>
                {% endif %}
            </div>
        </section>

        {% if result.openPosition %}
            <section class="table-panel open-position-panel" aria-labelledby="open-position-title">
                <header>
                    <h2 id="open-position-title">Position ouverte simulée</h2>
                    <span class="signal {{ result.openPosition.signal }}">{{ result.openPosition.signal }}</span>
                </header>

                <div class="component-strip">
                    <div>
                        <span class="muted">ETF</span>
                        <strong>{{ result.openPosition.symbol }}</strong>
                    </div>
                    <div>
                        <span class="muted">Entrée</span>
                        <strong>{{ result.openPosition.entryDate|date('d/m/Y') }}</strong>
                    </div>
                    <div>
                        <span class="muted">Prix entrée</span>
                        <strong>{{ result.openPosition.entryPrice|number_format(2, '.', ' ') }}</strong>
                    </div>
                    <div>
                        <span class="muted">Stop</span>
                        <strong>{{ result.openPosition.stopPrice|number_format(2, '.', ' ') }}</strong>
                    </div>
                </div>
            </section>
        {% endif %}

        <section class="table-panel trades-panel" aria-labelledby="trades-title">
            <header>
                <h2 id="trades-title">Trades fermés</h2>
                <span class="muted">Sorties au stop loss</span>
            </header>

            {% if result.trades is empty %}
                <div class="empty-state">Aucun trade fermé sur cette période.</div>
            {% else %}
                <table>
                    <thead>
                        <tr>
                            <th>ETF</th>
                            <th>Entrée</th>
                            <th>Sortie</th>
                            <th>Prix entrée</th>
                            <th>Prix sortie</th>
                            <th>Stop</th>
                            <th>Score</th>
                            <th>Perf</th>
                            <th>Capital</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for trade in result.trades %}
                            <tr>
                                <td>
                                    <span class="symbol">{{ trade.symbol }}</span><br>
                                    <span class="muted">{{ trade.holdingDays }} jour{{ trade.holdingDays > 1 ? 's' : '' }}</span>
                                </td>
                                <td>{{ trade.entryDate|date('d/m/Y') }}</td>
                                <td>{{ trade.exitDate|date('d/m/Y') }}</td>
                                <td>{{ trade.entryPrice|number_format(2, '.', ' ') }}</td>
                                <td>{{ trade.exitPrice|number_format(2, '.', ' ') }}</td>
                                <td>{{ trade.stopPrice|number_format(2, '.', ' ') }}</td>
                                <td>{{ trade.score|number_format(2, '.', ' ') }}</td>
                                <td class="{{ trade.returnPercent >= 0 ? 'positive' : 'negative' }}">{{ trade.returnPercent|number_format(2, '.', ' ') }} %</td>
                                <td>{{ trade.capitalAfterExit|number_format(2, '.', ' ') }} EUR</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </section>
    </main>
{% endblock %}
