{% extends 'base.html.twig' %}

{% block title %}tradeIA{% endblock %}

{% block body %}
    {% set staticExport = app.request.attributes.get('static_export', false) %}

    <main class="app-shell">
        <header class="topbar">
            <div class="brand">
                <strong>tradeIA</strong>
                <span>Momentum ETF</span>
            </div>
            <div class="header-actions">
                {% if not staticExport %}
                    <a class="text-button" href="{{ path('app_backtest') }}">Backtest</a>
                {% endif %}
                <span class="muted">{{ universe|length }} ETF suivi{{ universe|length > 1 ? 's' : '' }}</span>
            </div>
        </header>

        {% include '_static_export_notice.html.twig' %}

        {% set successFlashes = app.flashes('success') %}
        {% if successFlashes is not empty %}
            <div class="flash-list" aria-label="Notifications">
                {% for message in successFlashes %}
                    <div class="flash success">{{ message }}</div>
                {% endfor %}
            </div>
        {% endif %}

        {% include 'home/_decision_panel.html.twig' %}

        <div class="page-grid {{ staticExport ? 'static-page-grid' : '' }}">
            {% if not staticExport %}
                {% include 'home/_import_panel.html.twig' %}
            {% endif %}

            {% include 'home/_universe_table.html.twig' %}
            {% include 'home/_momentum_ranking.html.twig' %}
        </div>
    </main>
{% endblock %}
