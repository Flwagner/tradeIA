{% extends 'base.html.twig' %}

{% block title %}tradeIA{% endblock %}

{% block body %}
    <main class="app-shell">
        <header class="topbar">
            <div class="brand">
                <strong>tradeIA</strong>
                <span>Momentum ETF</span>
            </div>
            <div class="header-actions">
                <a class="text-button" href="{{ path('app_backtest') }}">Backtest</a>
                <span class="muted">{{ universe|length }} ETF suivi{{ universe|length > 1 ? 's' : '' }}</span>
            </div>
        </header>

        {% set successFlashes = app.flashes('success') %}
        {% if successFlashes is not empty %}
            <div class="flash-list" aria-label="Notifications">
                {% for message in successFlashes %}
                    <div class="flash success">{{ message }}</div>
                {% endfor %}
            </div>
        {% endif %}

        <div class="page-grid">
            <section class="tool-panel" aria-labelledby="import-title">
                <h1 id="import-title">Import ETF</h1>

                <form method="post">
                    <input type="hidden" name="import_source" value="manual">

                    <div class="field">
                        <label for="isins">Codes ISIN</label>
                        <textarea id="isins" name="isins" spellcheck="false" placeholder="LU1681043599">{{ isins }}</textarea>
                    </div>

                    <div class="field">
                        <label for="from">Historique depuis</label>
                        <input id="from" name="from" type="date" value="{{ from }}">
                    </div>

                    <button type="submit">Importer</button>
                </form>

                <form class="bourso-import-form" method="post">
                    <input type="hidden" name="import_source" value="boursobank_top">
                    <input type="hidden" name="from" value="{{ from }}">

                    <div class="field compact-field">
                        <label for="top_count">Top Boursobank</label>
                        <input id="top_count" name="top_count" type="number" min="1" max="20" value="10">
                    </div>

                    <button type="submit">Importer le top</button>
                </form>

                {% if importResults is not empty %}
                    <div class="result-list" aria-label="Resultat import">
                        {% for result in importResults %}
                            <article class="result {{ result.status }}">
                                <strong>
                                    {% if result.status == 'success' %}
                                        {{ result.symbol }} · {{ result.providerSymbol }}
                                    {% else %}
                                        {{ result.isin ?: 'Import refuse' }}
                                    {% endif %}
                                </strong>

                                {% if result.status == 'success' %}
                                    <span class="muted">{{ result.name }}</span>
                                    <div class="metric-strip">
                                        <span class="metric">{{ result.fetched }} récupérés</span>
                                        <span class="metric">{{ result.inserted }} créés</span>
                                        <span class="metric">{{ result.updated }} mis à jour</span>
                                    </div>
                                {% else %}
                                    <span class="muted">{{ result.message }}</span>
                                {% endif %}
                            </article>
                        {% endfor %}
                    </div>
                {% endif %}
            </section>

            <section class="table-panel" aria-labelledby="universe-title">
                <header>
                    <h2 id="universe-title">Univers ETF</h2>
                    <div class="header-actions">
                        <span class="muted">Prix quotidiens</span>
                        <form method="post" action="{{ path('app_etf_refresh_all_prices') }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('refresh_prices_all_etfs') }}">
                            <button class="icon-button" type="submit" title="Rafraîchir tous les prix" aria-label="Rafraîchir tous les prix">
                                &#8635;
                            </button>
                        </form>
                        <form
                            method="post"
                            action="{{ path('app_etf_delete_all') }}"
                            onsubmit="return confirm('Supprimer tous les ETF et toutes leurs donnees ?');"
                        >
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_all_etfs') }}">
                            <button class="icon-button danger" type="submit" title="Supprimer tous les ETF" aria-label="Supprimer tous les ETF">
                                &#128465;
                            </button>
                        </form>
                    </div>
                </header>

                {% if universe is empty %}
                    <div class="empty-state">Aucun ETF importé.</div>
                {% else %}
                    <table>
                        <thead>
                            <tr>
                                <th>ETF</th>
                                <th>ISIN</th>
                                <th>Dernier prix</th>
                                <th>Points</th>
                                <th class="actions-column"><span class="sr-only">Actions</span></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in universe %}
                                <tr>
                                    <td>
                                        <a class="symbol symbol-link" href="{{ path('app_etf_show', { id: row.etf.id }) }}">{{ row.etf.symbol }}</a><br>
                                        <span class="muted">{{ row.etf.name }}</span>
                                    </td>
                                    <td>{{ row.etf.isin }}</td>
                                    <td>
                                        {% if row.latestPrice %}
                                            {{ row.latestPrice.pricedAt|date('d/m/Y') }}<br>
                                            <span class="muted">{{ row.latestPrice.closePrice }} {{ row.etf.currency }}</span>
                                        {% else %}
                                            <span class="muted">-</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ row.pricePointCount }}</td>
                                    <td class="actions-cell">
                                        <div class="row-actions">
                                            <form
                                                method="post"
                                                action="{{ path('app_etf_refresh_prices', { id: row.etf.id }) }}"
                                            >
                                                <input type="hidden" name="_token" value="{{ csrf_token('refresh_prices_etf_' ~ row.etf.id) }}">
                                                <button class="icon-button" type="submit" title="Rafraîchir les prix {{ row.etf.symbol }}" aria-label="Rafraîchir les prix {{ row.etf.symbol }}">
                                                    &#8635;
                                                </button>
                                            </form>

                                            <form
                                                method="post"
                                                action="{{ path('app_etf_delete', { id: row.etf.id }) }}"
                                                onsubmit="return confirm('Supprimer {{ row.etf.symbol|e('js') }} et toutes ses donnees ?');"
                                            >
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete_etf_' ~ row.etf.id) }}">
                                                <button class="icon-button danger" type="submit" title="Supprimer {{ row.etf.symbol }}" aria-label="Supprimer {{ row.etf.symbol }}">
                                                    &#128465;
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% endif %}
            </section>

            <section class="table-panel ranking-panel" aria-labelledby="momentum-title">
                <header>
                    <h2 id="momentum-title">Classement momentum</h2>
                    <div class="header-actions">
                        <span class="muted">Stratégie momentum_v1</span>
                        <form method="post" action="{{ path('app_momentum_refresh') }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('refresh_momentum') }}">
                            <button class="icon-button" type="submit" title="Recalculer le score momentum" aria-label="Recalculer le score momentum">
                                &#8635;
                            </button>
                        </form>
                    </div>
                </header>

                {% if momentumRanking is empty %}
                    <div class="empty-state">Aucun score calculé.</div>
                {% else %}
                    <table>
                        <thead>
                            <tr>
                                <th>Rang</th>
                                <th>ETF</th>
                                <th>Score</th>
                                <th>Signal</th>
                                <th>Perf 6M</th>
                                <th>Perf 12M</th>
                                <th>Volatilité</th>
                                <th>Stop</th>
                                <th>MM200</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in momentumRanking %}
                                {% set snapshot = row.snapshot %}
                                {% set stopAdvice = row.trailingStopAdvice %}
                                <tr>
                                    <td>{{ loop.index }}</td>
                                    <td>
                                        <a class="symbol symbol-link" href="{{ path('app_etf_show', { id: snapshot.etf.id }) }}">{{ snapshot.etf.symbol }}</a><br>
                                        <span class="muted">{{ snapshot.computedAt|date('d/m/Y') }}</span>
                                    </td>
                                    <td><span class="score">{{ snapshot.score }}</span></td>
                                    <td><span class="signal {{ snapshot.signal }}">{{ snapshot.signal }}</span></td>
                                    <td>{{ snapshot.performance6Months is not null ? snapshot.performance6Months ~ ' %' : '-' }}</td>
                                    <td>{{ snapshot.performance12Months is not null ? snapshot.performance12Months ~ ' %' : '-' }}</td>
                                    <td>{{ snapshot.volatilityAnnualized is not null ? snapshot.volatilityAnnualized ~ ' %' : '-' }}</td>
                                    <td>
                                        {% if stopAdvice.available %}
                                            <span class="symbol">{{ stopAdvice.recommended.percentage|number_format(1, '.', ' ') }} %</span><br>
                                            <span class="muted">{{ stopAdvice.recommended.stopPrice|number_format(2, '.', ' ') }} {{ snapshot.etf.currency }}</span>
                                        {% else %}
                                            <span class="muted">-</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if snapshot.movingAverage200 %}
                                            {{ snapshot.movingAverage200 }}<br>
                                            <span class="muted">{{ snapshot.distanceToMovingAverage200 is not null ? snapshot.distanceToMovingAverage200 ~ ' %' : '-' }}</span>
                                        {% else %}
                                            <span class="muted">-</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% endif %}
            </section>
        </div>
    </main>
{% endblock %}
