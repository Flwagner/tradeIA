#!/usr/bin/env bash
set -euo pipefail

remote_name="${1:-origin}"
zero_sha="0000000000000000000000000000000000000000"
deploy_needed=0

if [[ "${STATIC_DEPLOY_ON_PUSH:-1}" == "0" ]]; then
  echo "Static deploy hook disabled because STATIC_DEPLOY_ON_PUSH=0."
  exit 0
fi

while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "${local_sha}" == "${zero_sha}" ]]; then
    continue
  fi

  if [[ "${remote_ref}" == "refs/heads/main" ]]; then
    deploy_needed=1
  fi
done

if [[ "${deploy_needed}" != "1" ]]; then
  exit 0
fi

echo "pre-push: deploying static site before pushing main..."
STATIC_DEPLOY_REMOTE="${remote_name}" bin/deploy-static
